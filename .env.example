# Solana RPC. Server-side only — the browser hits /api/rpc which proxies
# here, so the URL (and any API key in it) never enters the public bundle.
# Defaults to the public mainnet endpoint when unset.
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Jupiter Swap API (server-side only — must NOT have NEXT_PUBLIC_ prefix).
# Used by /api/jupiter/* proxy routes that build multi-hop swaps.
# Get one at https://portal.jup.ag/.
JUPITER_API_KEY=jup_YOUR_KEY

# Wire integrator fee. The fee is taken in the OUTPUT mint of each Jupiter
# leg and routed to an ATA owned by NEXT_PUBLIC_WIRE_FEE_OWNER. Both vars
# must be set together to enable the fee. Set BPS to 0 (or leave unset)
# for self-hosters who don't want to charge a fee.
NEXT_PUBLIC_WIRE_FEE_OWNER=
NEXT_PUBLIC_WIRE_FEE_BPS=0

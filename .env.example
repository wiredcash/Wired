# Public RPC the browser uses. For best UX use a paid RPC (Helius/Triton/etc).
# The repo ships a Helius default; override here if you want your own key.
NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Optional: separate RPC the CLI scripts use
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Jupiter Swap API (server-side only — must NOT have NEXT_PUBLIC_ prefix).
# Used by /api/jupiter/* proxy routes that build multi-hop swaps.
# Get one at https://portal.jup.ag/.
JUPITER_API_KEY=jup_YOUR_KEY
